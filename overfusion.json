      "slot": 3
    },
    {
      "key": "F4",
      "task": "save",
      "slot": 4
    },
    {
      "key": "4",
      "task": "load",
      "slot": 4
    },
    {
      "key": "F5",
      "task": "save",
      "slot": 5
    },
    {
      "key": "5",
