{
  "speed": 1.0,
  "font_scale": 1.0,
  "force_resolution": [0, 0],
  "forced_window_resize": false,
  "force_custom_window": false,
  "disable_fullscreen": true,
  "wait_for_debugger": false,
  "show_menu": false,
  "show_info": true,
  "emulate_user_timers": true,
  "emulate_mm_timers": true,
  "virtual_fs": true,
  "disable_threads": false,
  "delay_thread_hook": false,
  "no_ini_hooks": true,
  "boxed_mode": false,
  "disable_dark_mode_support": false,
  "disable_app_menu": true,
  "allow_timers_fix": true,
  "allow_direct_capture": true,
  "allow_audio_hook": false,
  "disable_audio": true,
  "record_audio": false,
  "support_audio_panning": false,
  "draw_cursor": true,
  "pixel_filter": true,
  "ui_pixel_filter": true,
  "save_vfs": true,
  "pause_on_scene_switch": false,
  "disable_viewport": false,
  "disable_perspective": false,
  "cmdline_append": " /DEBUG /NOVSYNC /MIS0 /NOC",
  "ffmpeg_cmdline": "ffmpeg -y -f:v rawvideo -s $SIZE -pix_fmt rgb32 -r $FPS -i - -an -vcodec h264_nvenc -b:v 10000k \"$CWD\\$PROJ\\video_$ID.mp4\"",
  "binds": [
    {
      "key": "m",
      "task": "mouse_down",
      "target": "lbutton"
    },
    {
      "key": "n",
      "task": "mouse_move"
    },
    {
      "key": "left",
      "task": "map",
      "target": "left"
    },
    {
      "key": "right",
      "task": "map",
      "target": "right"
    },
    {
      "key": "up",
      "task": "map",
      "target": "up"
    },
    {
      "key": "down",
      "task": "map",
      "target": "down"
    },
    {
      "key": "shift",
      "task": "map",
      "target": "shift"
    },
    {
      "key": "Enter",
      "task": "map",
      "target": "Enter"
    },
    {
      "key": "R",
      "task": "map",
      "target": "R"
    },
    {
      "key": "S",
      "task": "map",
      "target": "S"
    },
    {
      "key": "Z",
      "task": "map",
      "target": "Z"
    },
    {
      "key": "X",
      "task": "map",
      "target": "X"
    },
    {
      "key": "I",
      "task": "map",
      "target": "F2"
    },
    {
      "key": "O",
      "task": "map",
      "target": "F3"
    },
    {
      "key": "P",
      "task": "map",
      "target": "Esc"
    },
    {
      "key": "Del",
      "task": "map",
      "target": "Del"
    },
    {
      "key": "TAB",
      "task": "fast",
      "toggle": false
    },
    {
      "key": "Pause",
      "task": "play",
      "toggle": true
    },
    {
      "key": "Space",
      "task": "play",
      "toggle": false
    },
    {
      "key": "Q",
      "task": "replay_mode",
      "value": 0
    },
    {
      "key": "F12",
      "task": "reset_game"
    },
    {
      "key": "V",
      "task": "advance"
    },
    {
      "key": "Insert",
      "task": "menu"
    },
    {
      "key": "F1",
      "task": "save",
      "slot": 1
    },
    {
      "key": "1",
      "task": "load",
      "slot": 1
    },
    {
      "key": "F2",
      "task": "save",
      "slot": 2
    },
    {
      "key": "2",
      "task": "load",
      "slot": 2
    },
    {
      "key": "F3",
