{
  "fps": 0,
  "show_menu": false,
  "show_info": true,
  "emulate_user_timers": true,
  "emulate_mm_timers": true,
  "virtual_fs": true,
  "disable_threads": false,
  "delay_thread_hook": false,
  "no_ini_hooks": true,
  "boxed_mode": false,
  "disable_app_menu": true,
  "allow_timers_fix": true,
  "allow_d3d9_recording": true,
  "allow_audio_hook": true,
  "disable_audio": true,
  "record_audio": false,
  "support_audio_panning": true,
  "cmdline_append": " /D3D9 /DEBUG /NOF /NOVSYNC /MIS0 /NOC",
  "ffmpeg_cmdline": "ffmpeg -y -f:v rawvideo -s $SIZE -pix_fmt rgb32 -r $FPS -i - -an -vcodec h264_nvenc -b:v 10000k $PROJ/$NAME.mp4",
  "binds": [
    {
      "key": "left",
      "task": "map",
      "target": "left"
    },
    {
      "key": "right",
      "task": "map",
      "target": "right"
    },
    {
      "key": "up",
      "task": "map",
      "target": "up"
    },
    {
      "key": "down",
      "task": "map",
      "target": "down"
    },
    {
      "key": "shift",
      "task": "map",
      "target": "shift"
    },
    {
      "key": "Enter",
      "task": "map",
      "target": "Enter"
    },
    {
      "key": "R",
      "task": "map",
      "target": "R"
    },
    {
      "key": "S",
      "task": "map",
      "target": "S"
    },
    {
      "key": "Z",
      "task": "map",
      "target": "Z"
    },
    {
      "key": "X",
      "task": "map",
      "target": "X"
    },
    {
      "key": "I",
      "task": "map",
      "target": "F2"
    },
    {
      "key": "O",
      "task": "map",
      "target": "F3"
    },
    {
      "key": "P",
      "task": "map",
      "target": "Esc"
    },
    {
      "key": "TAB",
      "task": "fast",
      "toggle": false
    },
    {
      "key": "Pause",
      "task": "play",
      "toggle": true
    },
    {
      "key": "Space",
      "task": "play",
      "toggle": false
    },
    {
      "key": "V",
      "task": "advance"
    },
    {
      "key": "Insert",
      "task": "menu"
    },
    {
      "key": "F1",
      "task": "save",
      "slot": 1
    },
    {
      "key": "1",
      "task": "load",
      "slot": 1
    },
    {
      "key": "F2",
      "task": "save",
      "slot": 2
    },
    {
      "key": "2",
